{
  "name": "eqoa-data",
  "version": "1.1.3",
  "description": "JSON file data for EQOA information such as guides/quests listed on Jadiction.com",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "images"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
      "./images/*": "./images/*"
  },
  "scripts": {
    "generate:contributors": "node scripts/generate-contributors.mjs",
    "generate:data": "node scripts/generate-json-exports.mjs",
    "generate:images": "node scripts/generate-images-export.mjs",
    "build": "npm run generate:data && npm run generate:images && tsup",
    "build:release": "npm run generate:contributors && npm run build",
    "prepack": "npm run build",
    "dev": "tsup --watch src/index.ts --format esm"
  },
  "keywords": [
    "everquest",
    "everquest online adventures",
    "everquest online adventures frontiers",
    "eqoa",
    "eqoa data",
    "eqoa guides",
    "eqoa quests",
    "eq data",
    "eq guides",
    "eq quests"
  ],
  "homepage": "https://github.com/Jadiction/EQOA-Data#readme",
  "bugs": {
    "url": "https://github.com/Jadiction/EQOA-Data/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jadiction/EQOA-Data.git"
  },
  "license": "ISC",
  "author": "Jad",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}